# 用 python -c "import secrets; print(secrets.token_hex(32))" 生成一个新的，不要用示例值
SECRET_KEY=

DATABASE_URL=postgresql+asyncpg://voice:voice@db:5432/voice
DB_PASSWORD=change-me

# 阿里云百炼（DashScope）API Key，在 https://dashscope.console.aliyun.com 申请
ALIBABA_API_KEY=

# 部署后的公网访问地址，录音文件识别接口需要（DashScope 要回源下载音频）
PUBLIC_BASE_URL=https://your-domain.example.com

DEBUG=false
