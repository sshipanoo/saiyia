# Generate a new one with: python -c "import secrets; print(secrets.token_hex(32))"
# Don't use the example value below.
SECRET_KEY=

DATABASE_URL=postgresql+asyncpg://voice:voice@db:5432/voice
DB_PASSWORD=change-me

# --- Provider selection -----------------------------------------------------
# Each capability picks its own provider independently — mix and match freely.
# Currently supported: dashscope, openai (see app/providers/ to add more).
CHAT_PROVIDER=dashscope
TTS_PROVIDER=dashscope
ASR_PROVIDER=dashscope

# Alibaba Cloud Model Studio (DashScope) — apply for a key at
# https://dashscope.console.aliyun.com
ALIBABA_API_KEY=

# OpenAI — only needed if you set one of the *_PROVIDER vars above to "openai".
# OPENAI_BASE_URL also works for any OpenAI-compatible endpoint (Groq,
# Together, DeepSeek, a self-hosted vLLM server, etc.) for CHAT_PROVIDER.
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Real-time streaming ASR (the /asr/stream WebSocket) is a transparent relay —
# it forwards bytes/text without interpreting them, so it works with any
# WebSocket-based realtime speech API. Defaults to DashScope; point these at
# a different provider if you want realtime ASR from somewhere else.
# REALTIME_ASR_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference
# REALTIME_ASR_AUTH_HEADER=Bearer sk-...

# Your deployment's public-facing URL. Needed when ASR_PROVIDER=dashscope
# (DashScope's async transcription task has to fetch the audio from a public
# URL); not needed for providers like OpenAI Whisper that take the audio
# bytes directly.
PUBLIC_BASE_URL=https://your-domain.example.com

DEBUG=false
