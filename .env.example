# Generate a new one with: python -c "import secrets; print(secrets.token_hex(32))"
# Don't use the example value below.
SECRET_KEY=

DATABASE_URL=postgresql+asyncpg://voice:voice@db:5432/voice
DB_PASSWORD=change-me

# Alibaba Cloud Model Studio (DashScope) API key — apply for one at
# https://dashscope.console.aliyun.com
ALIBABA_API_KEY=

# Your deployment's public-facing URL. Needed by the file-transcription
# endpoint (DashScope has to fetch the audio from a public URL).
PUBLIC_BASE_URL=https://your-domain.example.com

DEBUG=false
